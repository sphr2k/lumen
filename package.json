{
  "name": "lumen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build --config apps/loader/vite.config.ts && tsc -p tsconfig.build.json",
    "dev": "vite --config apps/loader/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "validate": "bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "typescript": "^5.8.3",
    "vite": "^5.2.0",
    "vitest": "^3.2.4"
  }
}
